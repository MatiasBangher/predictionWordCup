# ==========================================
# CONFIGURACIÓN DE LA APP FIJINIS - MUNDIAL
# ==========================================

# 1. The Odds API (Cuotas en vivo)
# Consíguela en: https://the-odds-api.com/
ODDS_API_KEY="TU_API_KEY_AQUI"

# 2. API-Football (Estadísticas y Rachas)
# Consíguela en: https://www.api-football.com/ o via RapidAPI
API_FOOTBALL_KEY="TU_API_KEY_AQUI"

# 3. Base de Datos (Opcional - Para cuando uses PostgreSQL)
# Si lo dejas vacío, el sistema usará SQLite local (prediction_wc.db) por defecto.
# DATABASE_URL="postgresql://user:password@localhost:5432/prediction_db"

# 4. Groq API (Para el LLM)
# Consíguela en: https://console.groq.com/
GROQ_API_KEY="TU_API_KEY_AQUI"
